ZHIPUAI_API_KEY=replace_with_your_rotated_key
GLM_MODEL=glm-4.5-air
GLM_BASE_URL=https://open.bigmodel.cn/api/paas/v4/
GLM_TEMPERATURE=0
GLM_MAX_TOKENS=500
GLM_TIMEOUT_SECONDS=60
GLM_MAX_RETRIES=2
GLM_EMBEDDING_MODEL=embedding-3
